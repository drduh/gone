<!-- config.tmpl -->
{{ define "config" }}
  <details>
  <summary>config</summary>
    <div class="box">
      {{- template "selectRefresh" . }}
      {{ if .Paths.UserRemask }}
        {{- template "selectRemask" . }}
      {{ end }}
      <br>
      {{- template "selectClear" . }}
    </div>
  </details>
{{ end }}
