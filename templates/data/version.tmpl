<!-- version.tmpl -->
{{ define "version" }}
        <a href="https://github.com/drduh/gone">{{ .Version.id }}-{{ .Version.version }}</a><br>
        up {{ .Uptime }} on {{ .Hostname }}<br>
        built by {{ .Version.user }} from {{ .Version.path }}<br>
        on {{ .Version.host }} ({{ .Version.arch }}/{{ .Version.os }})<br>
        at {{ .Version.time }} with <a href="https://go.dev/">{{ .Version.go }}</a>
{{ end }}
