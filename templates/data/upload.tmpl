<!-- upload.tmpl -->
{{ define "upload" }}
  <div class="box">
    <form action="{{ .Paths.Upload }}"
         enctype="multipart/form-data"
          method="post">
      <input type="file" multiple required
            class="selectFile"
             name="file"
            title="file(s) to upload">
      <br>
      <input type="number"
            class="selectAllowDownloads"
              max="{{ .Limit.FileLimits.MaxDownloads }}"
              min="1"
             name="downloads"
             step="1"
            title="number of allowed downloads"
      placeholder="{{ .Default.Downloads }}">
      <input type="text"
            class="selectAllowDuration"
             name="duration"
      placeholder="{{ .DefaultDuration }}"
            title="expire file after duration">
      {{ if .Auth.Require.Upload }} {{ template "auth" . }} {{ end }}
      <br>
      <input type="submit"
            class="selectSubmit"
            title="upload selected file"
            value="upload">
    </form>
  </div>
{{ end }}
