<!-- wall.tmpl -->
{{ define "wall" }}
  <div class="box">
    <form action="{{ .Paths.Wall }}"
         enctype="application/x-www-form-urlencoded"
              id="wall"
          method="post">
      <textarea class="wallContent"
                 cols="32" rows="12"
                 form="wall"
                   id="wall"
            maxlength="{{ .Limit.MaxSizeWall }}"
                 name="wall"
                title="add or edit content">
      {{- .Storage.WallContent -}}
      </textarea>
      <br>
      {{ if .Auth.Require.Wall }} {{ template "auth" . }} {{ end }}
      <input class="selectPost"
             title="save contents"
              type="submit"
             value="save">
    </form>
    <form action="{{ .Paths.Wall }}"
          method="post"
           style="display:inline;">
      <input type="hidden" name="clear" value="true">
      <button class="selectClear" {{ if not .Storage.WallContent }} disabled {{ end }}
              title="clear wall"
               type="submit">clear</button>
    </form>
    <form action="{{ .Paths.Wall }}"
          method="get"
           style="display:inline;">
      <input type="hidden" name="download" value="all">
      <button class="selectDownload" {{ if not .Storage.WallContent }} disabled {{ end }}
              title="download wall"
               type="submit">download</button>
    </form>
  </div>
{{ end }}
