<!-- list.tmpl -->
{{ define "list" }}
  <div class="box">
    {{ if not .Storage.Files }}
    <p>{{ .NoFiles }}</p>
    {{ else }}
    {{ if .Auth.Require.List }}
    <form action="{{ .Paths.List }}"
          method="post">
      {{ template "auth" . }}
      <input class="selectSubmit"
              type="submit"
             value="list">
    </form>
    {{ end }}
    <form action="{{ .Paths.Download }}"
          method="post">
      <br>
      {{ if not .Auth.Require.List }}
      <table>
        <thead>
          <tr>
            <th>File</th>
            <th>Size</th>
            <th>Type</th>
            <th>User</th>
            <th>Time</th>
          </tr>
        </thead>
        <tbody>
        {{ range .Storage.Files }}
        <tr class="list-row">
          <td>
            <label for="{{ printf "%.8s" .Id }}">{{ .Name }}
              <br>({{ printf "%.8s" .Sum }})</label>
            <input id="{{ printf "%.8s" .Id }}"
                 name="name"
                 type="radio"
                value="{{ .Id }}" required>
          </td>
          <td><label for="{{ printf "%.8s" .Id }}">{{ .Size }}</label></td>
          <td><label for="{{ printf "%.8s" .Id }}">{{ .Type }}</label></td>
          <td><label for="{{ printf "%.8s" .Id }}">{{ .Owner.Mask }}</label></td>
          <td><label for="{{ printf "%.8s" .Id }}">{{ .Time.Remain }}</label></td>
        </tr>
        {{ end }}
        </tbody>
      </table>
      <br>
      {{ else }}
      <input class="selectFilename"
                id="name"
              name="name"
       placeholder="{{ .Placeholder.File }}"
             title="download file by id or name"
              type="text" required>
      {{ end }}
      {{ if .Auth.Require.Download }} {{ template "auth" . }} {{ end }}
      <input class="selectSubmit"
             title="download selected file"
              type="submit"
             value="download">
    </form>
    {{ end }}
  </div>
{{ end }}
