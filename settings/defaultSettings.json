{
  "serverAddr":    "127.0.0.1",
  "serverPort":    8080,
  "showBuild":     true,
  "audit": {
    "logDebug":    false,
    "logFilename": "",
    "timeFormat":  "Monday Jan 2 15:04:05"
  },
  "auth": {
    "basic": {
      "field":     "X-Auth",
      "token":     "mySecret"
    },
    "require": {
      "assets":    false,
      "clear":     true,
      "download":  true,
      "list":      false,
      "msg":       false,
      "msgAdd":    false,
      "msgClear":  true,
      "random":    false,
      "remask":    true,
      "root":      false,
      "static":    false,
      "status":    true,
      "upload":    true,
      "userInfo":  false,
      "wall":      false
    },
    "tarpitDelay": "2s"
  },
  "default": {
    "downloads":   1,
    "duration":    "5m"
  },
  "error": {
    "copy":        "file copy fail",
    "deny":        "not authorized",
    "fileSize":    "file too large",
    "fileSizeAll": "size limit met",
    "form":        "file form fail",
    "msgCount":    "msgs count met",
    "msgLength":   "msg length met",
    "noFilename":  "need file name",
    "noFiles":     "no files found",
    "notFound":    "file not found",
    "rateLimit":   "req rate limit",
    "tmplExec":    "failed to exec",
    "tmplParse":   "failed parsing"
  },
  "indexPage": {
    "csp":         true,
    "title":       "gone",
    "cookie": {
      "id":        "goneTheme",
      "time":      "192h"
    },
    "placeholder": {
      "auth":      "enter secret token",
      "file":      "enter file name/id",
      "message":   "enter text message"
    },
    "style": {
      "allowPick": true,
      "theme":     "auto",
      "available": [
        "light", "dark", "navy", "rose", "green",
        "lime", "pink", "gold", "purple", "lush",
        "beach", "dusk", "neon", "night", "ember"
      ]
    }
  },
  "limit": {
    "reqsPerMinute":    30,
    "fileLimits": {
      "expiryCheck":    "30s",
      "maxDownloads":   100,
      "maxDuration":    "192h",
      "nameExtraChars": "_.- ",
      "nameLength":     64,
      "sizeEachMb":     512,
      "sizeTotalMb":    4096
    },
    "messageLimits": {
      "maxCount":       32,
      "lengthChars":    128
    },
    "randomLimits": {
      "strCount":       16
    },
    "wallLimits": {
      "lengthChars":    2560
    }
  },
  "paths": {
    "assets":      "/assets/",
    "clear":       "/clear",
    "download":    "/download/",
    "list":        "/list",
    "msg":         "/msg",
    "msgAdd":      "/msg/add",
    "msgClear":    "/msg/clear",
    "random":      "/random/",
    "root":        "/",
    "static":      "/static",
    "status":      "/status",
    "upload":      "/upload",
    "userInfo":    "/user/info",
    "userRemask":  "/user/remask",
    "wall":        "/wall"
  }
}
