{
  "port":          8080,
  "showBuild":     true,
  "audit": {
    "logFile":     "",
    "timeFormat":  "Monday Jan 2 15:04"
  },
  "auth": {
    "basic": {
      "field":     "X-Auth",
      "token":     "mySecret"
    },
    "require": {
      "clear":     false,
      "download":  true,
      "list":      false,
      "message":   false,
      "random":    false,
      "root":      false,
      "static":    false,
      "status":    false,
      "upload":    false,
      "user":      false,
      "wall":      false
    }
  },
  "default": {
    "downloads":   1,
    "duration":    "5m"
  },
  "error": {
    "copy":        "file copy fail",
    "deny":        "not authorized",
    "fileSize":    "file too large",
    "fileSizeAll": "size limit met",
    "form":        "file form fail",
    "noFilename":  "need file name",
    "noFiles":     "no files found",
    "notFound":    "file not found",
    "rateLimit":   "limit exceeded",
    "tmplExec":    "failed to exec",
    "tmplParse":   "failed parsing"
  },
  "indexPage": {
    "csp":         true,
    "title":       "gone",
    "cookie": {
      "id":        "goneTheme",
      "time":      "192h"
    },
    "placeholder": {
      "auth":      "enter secret",
      "file":      "enter name or id",
      "message":   "enter message"
    },
    "style": {
      "allowPick": true,
      "theme":     "auto",
      "available": [
        "dark",
        "light",
        "navy",
        "rose",
        "green",
        "lime",
        "pink",
        "gold",
        "purple",
        "lush",
        "beach",
        "dusk",
        "neon",
        "night"
      ]
    }
  },
  "limit": {
    "reqsPerMinute":    30,
    "fileLimits": {
      "expiryCheck":    "30s",
      "maxDownloads":   100,
      "maxDuration":    "192h",
      "nameExtraChars": "_.- ",
      "nameLength":     64,
      "sizeEachMb":     512,
      "sizeTotalMb":    4096
    },
    "messageLimits": {
      "lengthChars": 128
    },
    "wallLimits": {
      "lengthChars": 2560
    }
  },
  "paths": {
    "assets":      "/assets/",
    "clear":       "/clear",
    "download":    "/download/",
    "list":        "/list",
    "message":     "/msg",
    "random":      "/random/",
    "root":        "/",
    "static":      "/static",
    "status":      "/status",
    "upload":      "/upload",
    "user":        "/user",
    "wall":        "/wall"
  }
}
